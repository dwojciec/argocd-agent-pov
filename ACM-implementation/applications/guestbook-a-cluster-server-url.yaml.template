# Same workload as guestbook-a-cluster.yaml but using an explicit principal URL + agentName
# (equivalent style to the Argo CD UI / some docs).
#
# Generate and apply from repo root (reuse PRINCIPAL_ROUTE_HOST from envsubst.env — host only, no https://):
#   set -a && [ -f envsubst.env ] && . envsubst.env && set +a
#   envsubst < ACM-implementation/applications/guestbook-a-cluster-server-url.yaml.template | oc apply -f -
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: guestbook
  namespace: agent-managed
spec:
  project: default
  destination:
    namespace: a-cluster
    server: https://${PRINCIPAL_ROUTE_HOST}?agentName=a-cluster
  source:
    repoURL: https://github.com/argoproj/argocd-example-apps.git
    path: guestbook
    targetRevision: HEAD
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
