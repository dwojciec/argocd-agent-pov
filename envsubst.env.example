# Copier vers envsubst.env (ne pas committer les secrets réels) :
#   cp envsubst.env.example envsubst.env
# Puis : set -a && source envsubst.env && set +a
#
# Host de la Route HTTPS du Principal (sans https://, sans :443) — oc get route -n gitops-control-plane --context principal
# Le chart redhat-argocd-agent utilise `server` + `serverPort` : ne pas inclure le port dans cette variable.
export PRINCIPAL_ROUTE_HOST=argocd-agent-principal-argocd.apps.example.com

# Service resource-proxy du Principal, host:port — oc get svc -n gitops-control-plane --context principal
export RESOURCE_PROXY_SERVER=argocd-agent-principal-resource-proxy.gitops-control-plane.svc.cluster.local:9090

# Namespace Argo CD / Principal (défaut du PoV)
export PRINCIPAL_NS=gitops-control-plane
